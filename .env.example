# ============================================================
# BikeOstrava - environment variables
# Copy to .env and fill in values for local development.
# Never commit .env to version control.
# ============================================================

# Django
SECRET_KEY=django-insecure-replace-me-with-a-strong-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL + PostGIS
# For local dev: create a PostGIS-enabled database first:
#   createdb bikeostrava && psql bikeostrava -c "CREATE EXTENSION postgis;"
PGDATABASE=bikeostrava
PGUSER=postgres
PGPASSWORD=postgres
PGHOST=localhost
PGPORT=5432

# CORS (leave blank to allow all in dev)
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

# Routing - GraphHopper (optional; leave blank to use free OSRM fallback)
# Get a key at https://www.graphhopper.com/ (free tier available)
GRAPHHOPPER_API_KEY=
GRAPHHOPPER_API_URL=https://graphhopper.com/api/1/route

# OSRM public API (no key needed - used as fallback)
OSRM_API_URL=https://router.project-osrm.org/route/v1

# Nominatim geocoding (OSM) - no key needed
NOMINATIM_USER_AGENT=BikeOstrava/1.0 (your-email@example.com)

# Overpass API (OSM bike paths / green zones) - no key needed
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Accident data is loaded from policie.gov.cz via management command:
#   python manage.py load_accidents
# No configuration needed - the command downloads directly from Czech Police.
